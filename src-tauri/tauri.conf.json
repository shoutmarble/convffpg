{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "convffpg",
  "version": "0.2.1",
  "identifier": "io.github.terry.convffpg",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "convffpg",
        "width": 1500,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "../flatpak/io.github.terry.convffpg.svg"
    ]
  }
}